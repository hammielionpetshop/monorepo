{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "JWT_SECRET", "JWT_REFRESH_SECRET", "CUSTOMER_JWT_SECRET", "ORDER_BRANCH_ID", "OTP_PROVIDER", "OTP_TTL_SECONDS", "FONNTE_TOKEN", "TURBO_TEAM", "TURBO_TOKEN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": false
    }
  }
}
