# Salin ke .env di folder ini sebelum `docker compose up -d`.
# Generate key: uuidgen | tr -d '-'  →  lalu hash: echo -n "<key>" | sha512sum
# WAHA_API_KEY di sini HARUS hash sha512 (server) — beda dari WAHA_API_KEY di
# apps/order-web/.env.local (ITU nilai plain-nya, dikirim sebagai header X-Api-Key).
WAHA_API_KEY=sha512:GANTI_DENGAN_HASH_SHA512
