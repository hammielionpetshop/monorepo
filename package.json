{
  "name": "hammielion-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:pos": "turbo dev --filter petshop-pos",
    "dev:backoffice": "turbo dev --filter backoffice",
    "db:migrate": "pnpm --filter @petshop/db db:migrate",
    "db:push": "pnpm --filter @petshop/db db:push",
    "db:studio": "pnpm --filter @petshop/db db:studio",
    "db:seed": "pnpm --filter @petshop/db db:seed",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@8.15.9"
}
